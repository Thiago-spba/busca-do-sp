rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /usuarios_autorizados/{uid} {
      // Usuario so pode ler o proprio documento (para checar se esta autorizado)
      allow read: if request.auth != null && request.auth.uid == uid;
      // Nenhuma escrita direta pelo navegador. Apenas a Cloud Function
      // (que usa o Admin SDK e ignora estas regras) pode escrever.
      allow write: if false;
    }

    // Bloqueia qualquer outra coisa por padrao
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
