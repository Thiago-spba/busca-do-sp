rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /usuarios_autorizados/{uid} {
      // Usuario so pode ler o proprio documento (para checar se esta autorizado)
      allow read: if request.auth != null && request.auth.uid == uid;
      // Nenhuma escrita direta pelo navegador. Apenas a Cloud Function
      // (que usa o Admin SDK e ignora estas regras) pode escrever.
      allow write: if false;

      // Historico de buscas: privado, o usuario le e escreve apenas o proprio
      match /buscas/{buscaId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Metadados do usuario (ex: nomes das listas personalizadas de favoritos)
      match /meta/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Bloqueia qualquer outra coisa por padrao
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
